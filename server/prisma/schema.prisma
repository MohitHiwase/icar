generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────
//  1. User
// ──────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         String   @default("user") // user | admin
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  dataSources       DataSource[]
  datasets          Dataset[]
  importJobs        ImportJob[]
  analysisPipelines AnalysisPipeline[]
  mapLayers         MapLayer[]
  reports           Report[]
  refreshTokens     RefreshToken[]

  @@index([role])
  @@map("users")
}

// ──────────────────────────────────────
//  1b. RefreshToken
// ──────────────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ──────────────────────────────────────
//  2. DataSource
// ──────────────────────────────────────
model DataSource {
  id         String    @id @default(uuid())
  name       String
  type       String    // 'API' | 'MANUAL'
  provider   String    // e.g. "Bhuvan", "Sentinel Hub"
  baseUrl    String?   @map("base_url")
  authConfig String?   @map("auth_config") // JSON string
  status     String    @default("active") // active | offline | error
  lastSyncAt DateTime? @map("last_sync_at")
  createdBy  String    @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Relations
  creator    User        @relation(fields: [createdBy], references: [id])
  datasets   Dataset[]
  importJobs ImportJob[]

  @@unique([name, createdBy])
  @@index([createdBy])
  @@index([status])
  @@index([type])
  @@map("data_sources")
}

// ──────────────────────────────────────
//  3. Dataset  (central entity)
// ──────────────────────────────────────
model Dataset {
  id               String    @id @default(uuid())
  name             String
  description      String?
  dataType         String    @map("data_type")   // satellite, climate, soil, etc.
  fileFormat       String    @map("file_format")  // csv, geojson, shapefile, geotiff
  filePath         String    @map("file_path")
  fileSizeBytes    BigInt    @map("file_size_bytes")
  origin           String    // api_import, manual_upload, merged, analysis_output
  qualityStatus    String    @default("raw") @map("quality_status") // raw, cleaned, standardized, merged
  parentDatasetIds String?   @map("parent_dataset_ids") // JSON string
  metadata         String?   // JSON string
  sourceId         String?   @map("source_id")
  uploadedBy       String    @map("uploaded_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  // Relations
  source         DataSource?     @relation(fields: [sourceId], references: [id])
  uploader       User            @relation(fields: [uploadedBy], references: [id])
  importJobs     ImportJob[]
  pipelineNodes  PipelineNode[]
  mapLayers      MapLayer[]
  reports        Report[]
  analysisResult AnalysisResult? @relation("GeneratedDataset")

  @@index([uploadedBy])
  @@index([sourceId])
  @@index([dataType])
  @@index([origin])
  @@index([qualityStatus])
  @@index([createdAt])
  @@map("datasets")
}

// ──────────────────────────────────────
//  4. ImportJob
// ──────────────────────────────────────
model ImportJob {
  id              String    @id @default(uuid())
  sourceId        String?   @map("source_id")
  datasetId       String?   @map("dataset_id")
  triggeredBy     String    @map("triggered_by")
  status          String    @default("queued") // queued, in_progress, completed, failed
  progressPercent Int       @default(0) @map("progress_percent")
  fileName        String?   @map("file_name")
  fileSizeBytes   BigInt?   @map("file_size_bytes")
  errorMessage    String?   @map("error_message")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  source  DataSource? @relation(fields: [sourceId], references: [id])
  dataset Dataset?    @relation(fields: [datasetId], references: [id])
  user    User        @relation(fields: [triggeredBy], references: [id])

  @@index([triggeredBy])
  @@index([sourceId])
  @@index([status])
  @@index([createdAt])
  @@map("import_jobs")
}

// ──────────────────────────────────────
//  5. AnalysisPipeline
// ──────────────────────────────────────
model AnalysisPipeline {
  id              String    @id @default(uuid())
  name            String
  description     String?
  status          String    @default("draft") // draft, ready, running, completed, failed
  executionConfig String?   @map("execution_config") // JSON string
  createdBy       String    @map("created_by")
  lastRunAt       DateTime? @map("last_run_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  creator     User                 @relation(fields: [createdBy], references: [id])
  nodes       PipelineNode[]
  connections PipelineConnection[]
  results     AnalysisResult[]

  @@index([createdBy])
  @@index([status])
  @@index([createdAt])
  @@map("analysis_pipelines")
}

// ──────────────────────────────────────
//  6. PipelineNode
// ──────────────────────────────────────
model PipelineNode {
  id             String   @id @default(uuid())
  pipelineId     String   @map("pipeline_id")
  label          String
  nodeType       String   @map("node_type")  // input, transform, output
  operation      String   // ndvi_calc, random_forest, etc.
  config         String?  // JSON string
  positionX      Float    @map("position_x")
  positionY      Float    @map("position_y")
  inputDatasetId String?  @map("input_dataset_id")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  pipeline       AnalysisPipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  inputDataset   Dataset?             @relation(fields: [inputDatasetId], references: [id])
  outConnections PipelineConnection[] @relation("SourceNode")
  inConnections  PipelineConnection[] @relation("TargetNode")

  @@index([pipelineId])
  @@index([inputDatasetId])
  @@index([nodeType])
  @@map("pipeline_nodes")
}

// ──────────────────────────────────────
//  7. PipelineConnection
// ──────────────────────────────────────
model PipelineConnection {
  id           String   @id @default(uuid())
  pipelineId   String   @map("pipeline_id")
  sourceNodeId String   @map("source_node_id")
  targetNodeId String   @map("target_node_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  pipeline   AnalysisPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  sourceNode PipelineNode     @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode PipelineNode     @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId])
  @@index([pipelineId])
  @@map("pipeline_connections")
}

// ──────────────────────────────────────
//  8. AnalysisResult
// ──────────────────────────────────────
model AnalysisResult {
  id                  String    @id @default(uuid())
  pipelineId          String    @map("pipeline_id")
  status              String    // processing, completed, failed
  resultType          String    @map("result_type") // geotiff, csv, json_metrics, vector_layer
  filePath            String?   @map("file_path")
  fileSizeBytes       BigInt?   @map("file_size_bytes")
  summaryMetrics      String?   @map("summary_metrics") // JSON string
  executionDurationMs Int?      @map("execution_duration_ms")
  errorMessage        String?   @map("error_message")
  generatedDatasetId  String?   @unique @map("generated_dataset_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  // Relations
  pipeline         AnalysisPipeline @relation(fields: [pipelineId], references: [id])
  generatedDataset Dataset?         @relation("GeneratedDataset", fields: [generatedDatasetId], references: [id])
  mapLayers        MapLayer[]
  reports          Report[]

  @@index([pipelineId])
  @@index([status])
  @@index([createdAt])
  @@map("analysis_results")
}

// ──────────────────────────────────────
//  9. MapLayer
// ──────────────────────────────────────
model MapLayer {
  id               String   @id @default(uuid())
  name             String
  description      String?
  layerType        String   @map("layer_type") // raster, vector, heatmap, point_cloud
  datasetId        String?  @map("dataset_id")
  analysisResultId String?  @map("analysis_result_id")
  renderConfig     String   @map("render_config") // JSON string
  isVisible        Boolean  @default(true) @map("is_visible")
  sortOrder        Int      @default(0) @map("sort_order")
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  dataset        Dataset?        @relation(fields: [datasetId], references: [id])
  analysisResult AnalysisResult? @relation(fields: [analysisResultId], references: [id])
  creator        User            @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
  @@index([datasetId])
  @@index([analysisResultId])
  @@map("map_layers")
}

// ──────────────────────────────────────
//  10. Report
// ──────────────────────────────────────
model Report {
  id               String   @id @default(uuid())
  title            String
  description      String?
  reportType       String   @map("report_type") // yield_analysis, soil_health, ndvi_index, etc.
  outputFormat     String   @map("output_format") // pdf, csv, xlsx
  filePath         String?  @map("file_path")
  fileSizeBytes    BigInt?  @map("file_size_bytes")
  status           String   @default("queued") // queued, processing, completed, failed
  datasetId        String?  @map("dataset_id")
  analysisResultId String?  @map("analysis_result_id")
  generatedBy      String   @map("generated_by")
  errorMessage     String?  @map("error_message")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  dataset        Dataset?        @relation(fields: [datasetId], references: [id])
  analysisResult AnalysisResult? @relation(fields: [analysisResultId], references: [id])
  generator      User            @relation(fields: [generatedBy], references: [id])

  @@index([generatedBy])
  @@index([status])
  @@index([datasetId])
  @@index([analysisResultId])
  @@index([createdAt])
  @@map("reports")
}
